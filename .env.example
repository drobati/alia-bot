# Discord Bot Configuration
BOT_TOKEN=your_discord_bot_token_here
NODE_ENV=development

# Database Configuration
MYSQLDB_DATABASE=aliadb
MYSQLDB_USER=aliabot
MYSQLDB_PASSWORD=your_mysql_password

# OpenAI Configuration (used by translate, dnd, motivational)
OPENAI_API_KEY=sk-your_openai_api_key_here

# OpenRouter Configuration (used by assistant responses via Grok)
OPENROUTER_API_KEY=sk-or-your_openrouter_api_key_here

# Stock Market API Configuration
POLYGON_API_KEY=your_polygon_api_key_here